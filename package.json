{
  "name": "frame",
  "private": true,
  "version": "0.1.0",
  "description": "FRAME — Focus, Resource and Activity Management Engine",
  "author": "BOS PPM",
  "homepage": "https://github.com/WoodyMonk-mint/FRAME",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "postinstall": "electron-builder install-app-deps",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "dev": "concurrently -k \"vite\" \"wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 npx --no electron . --no-sandbox\"",
    "dev:web": "vite",
    "build": "tsc -b && vite build",
    "package": "vite build && electron-builder",
    "package:linux": "vite build && electron-builder --linux",
    "package:mac": "vite build && electron-builder --mac",
    "package:win": "vite build && electron-builder --win",
    "lint": "eslint ."
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "framer-motion": "^12.38.0",
    "html-to-image": "^1.11.13",
    "jspdf": "^2.5.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.bos.FRAME",
    "productName": "FRAME",
    "copyright": "Copyright © 2026 BOS PPM",
    "directories": {
      "output": "release",
      "buildResources": "build-assets"
    },
    "files": [
      "dist/**",
      "electron/**",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**",
      "node_modules/bindings/**"
    ],
    "linux": {
      "target": [
        { "target": "AppImage", "arch": ["x64"] }
      ],
      "category": "Office",
      "maintainer": "BOS PPM"
    },
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] },
        { "target": "zip", "arch": ["x64", "arm64"] }
      ],
      "category": "public.app-category.business"
    },
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerHeaderIcon": "build-assets/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}

